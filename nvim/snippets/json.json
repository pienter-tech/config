{
  "composer-dry-vsc": {
    "prefix": "dry-vcs",
    "description": "Add VCS repository for DRY3 package from Bitbucket (git remote)",
    "body": [
      "\"repositories\": [",
      "  {",
      "    \"type\": \"vcs\",",
      "    \"url\": \"git@bitbucket.org:tallieu/dry3.git\"",
      "  }",
      "],"
    ]
  },
  "composer-dry-path": {
    "prefix": "dry-path",
    "description": "Add local path repository for DRY3 package with symlink (local development)",
    "body": [
      "\"repositories\": [",
      "  {",
      "    \"type\": \"path\",",
      "    \"url\": \"../dry3\",",
      "    \"options\": {",
      "      \"symlink\": true",
      "    }",
      "  }",
      "],"
    ]
  },
  "dap-dry-launc": {
    "prefix": "dry-dap-launch",
    "description": "",
    "body": [
      "{",
      " \"version\": \"0.2.0\",",
      " \"configurations\": [",
      " {",
      "   \"name\": \"Listen for Xdebug\",",
      "   \"type\": \"php\",",
      "   \"request\": \"launch\",",
      "   \"port\": 9003,",
      "   \"pathMappings\": {",
      "     \"/var/www/default/\": \"${workspaceFolder}/\",",
      "     \"/var/www/dry/src/dry/\": \"${workspaceFolder}/dry/\",",
      "     \"/var/www/dry/vendor/composer/\": \"${workspaceFolder}/vendor/composer/\",",
      "   }",
      " }",
      " ]",
      "}"
    ]
  }
}
