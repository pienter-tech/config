function cld() {
    local danger_flag=()
    if [[ "$1" == "--danger" ]]; then
        danger_flag=(--permission-mode bypassPermissions)
        shift
    fi
    claude "${danger_flag[@]}" --mcp-config "$CONFIG_DIR/claude/mcp.json" "$@"
}

