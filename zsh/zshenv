# Public environment variables (non-sensitive)
if [[ -f "$CONFIG_DIR/.env.public" ]]; then
  set -o allexport
  source "$CONFIG_DIR/.env.public"
  set +o allexport
fi

# EDITOR
export EDITOR="nvim"
export VISUAL="nvim"

# FZF
export FZF_DEFAULT_COMMAND='rg --files --hidden --glob "!.git"'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
